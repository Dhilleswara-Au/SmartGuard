# SmartGuard – copy to .env and set your own values. Never commit .env.

# -----------------------------------------------------------------------------
# Web & API
# -----------------------------------------------------------------------------
SMARTGUARD_SECRET_KEY=change_this_to_a_long_random_string
SMARTGUARD_ADMIN_USERNAME=admin
SMARTGUARD_ADMIN_PASSWORD=change_me
SMARTGUARD_API_KEY=change_this_api_key_for_mobile_and_detector
SMARTGUARD_PORT=5000
SMARTGUARD_DEBUG=false

# -----------------------------------------------------------------------------
# Geofencing (decimal degrees)
# -----------------------------------------------------------------------------
SMARTGUARD_HOME_LAT=0.0
SMARTGUARD_HOME_LON=0.0
SMARTGUARD_HOME_DISTANCE_METERS=100

# -----------------------------------------------------------------------------
# Telegram (alerts and interactive buttons)
# -----------------------------------------------------------------------------
SMARTGUARD_TELEGRAM_TOKEN=
SMARTGUARD_TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Optional: Healthchecks.io or similar (GET every 60s; alert if down)
# -----------------------------------------------------------------------------
SMARTGUARD_HEARTBEAT_URL=
